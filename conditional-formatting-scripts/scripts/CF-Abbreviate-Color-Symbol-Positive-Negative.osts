{"version":"0.3.0","body":"//  TYPE DEFINITIONS\n//  These interfaces define the shape of the TIERS and DEFAULT config objects so please don't edit them.\n// ─────────────────────────────────────────────────────────────────────────────\n\n// Shared styling properties used by both TierConfig and DefaultConfig.\ninterface StyleConfig {\n    prefix: string;      // symbol or emoji prepended to the number; \"\" = none\n    fontColor: string;   // hex font color e.g. \"#C00000\"; \"\" = keep existing\n    fillColor: string;   // hex cell background color e.g. \"#FFF2CC\"; \"\" = no fill\n    bold: boolean;       // true = bold font; false = regular weight\n    italic: boolean;     // true = italic font; false = upright\n}\n\n// Defines one magnitude tier (one conditional formatting rule).\n// POSITIVE_TIERS use greaterThanOrEqual; thresholds must be in descending order (B → M → K → n).\n// NEGATIVE_TIERS use lessThanOrEqual; thresholds must be in ascending order (-B → -M → -K → -n).\n// StopIfTrue prevents lower-priority rules from firing on already-matched cells.\ninterface TierConfig extends StyleConfig {\n    enabled: boolean;   // false = this tier is skipped entirely; no rule is added\n    threshold: number;  // inclusive bound; positive tiers use >=, negative tiers use <=\n    format: string;     // Excel number format string without the prefix\n}\n\n// Defines the catch-all rule for numeric cells not matched by any tier.\n// Fires for values between the lowest positive threshold and the lowest-magnitude negative threshold.\ninterface DefaultConfig extends StyleConfig {\n    enabled: boolean;   // false = unmatched numeric cells are left completely untouched\n    format: string;     // Excel number format string; \"\" = no format change (prefix also suppressed)\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction main(workbook: ExcelScript.Workbook): void {\n\n    // ─── CONFIGURATION — we can edit everything in this section based on our needs ──────────────────────\n\n    const APPLY_FONT_STYLING = true;   // false = skip all font/fill styling\n    const APPLY_PREFIX = true;         // false = skip all prefix symbols\n    const PREFIX_POSITION: \"before\" | \"fill\" = \"fill\";\n    // \"before\" = prefix immediately left of number\n    // \"fill\"   = prefix at left cell edge, number at right\n\n    // Thresholds must be in descending order (largest magnitude first: B → M → K → n).\n    const POSITIVE_TIERS: TierConfig[] = [\n        {\n            enabled: true,\n            threshold: 1_000_000_000,\n            format: '0.00,,,\"B\"',\n            prefix: \"🟢\",\n            fontColor: \"\",\n            fillColor: \"\",\n            bold: false,\n            italic: false,\n        },\n        {\n            enabled: true,\n            threshold: 1_000_000,\n            format: '0.00,,\"M\"',\n            prefix: \"🔵\",\n            fontColor: \"#1F497D\",\n            fillColor: \"\",\n            bold: false,\n            italic: false,\n        },\n        {\n            enabled: true,\n            threshold: 1_000,\n            format: '0.00,\"K\"',\n            prefix: \"🟡\",\n            fontColor: \"#808080\",\n            fillColor: \"\",\n            bold: false,\n            italic: false,\n        },\n        {\n            enabled: true,\n            threshold: 0,   // catches all positive values below the K tier down to zero\n            format: \"#,##0\",\n            prefix: \"⚪\",\n            fontColor: \"\",\n            fillColor: \"\",\n            bold: false,\n            italic: false,\n        },\n    ];\n\n    // Thresholds must be in ascending order (most negative first: -B → -M → -K → -n).\n    const NEGATIVE_TIERS: TierConfig[] = [\n        {\n            enabled: true,\n            threshold: -1_000_000_000,\n            format: '0.00,,,\"B\"',\n            prefix: \"💥\",\n            fontColor: \"#C00000\",\n            fillColor: \"\",\n            bold: true,\n            italic: false,\n        },\n        {\n            enabled: true,\n            threshold: -1_000_000,\n            format: '0.00,,\"M\"',\n            prefix: \"🧨\",\n            fontColor: \"#C00000\",\n            fillColor: \"\",\n            bold: false,\n            italic: false,\n        },\n        {\n            enabled: true,\n            threshold: -1_000,\n            format: '0.00,\"K\"',\n            prefix: \"🔴\",\n            fontColor: \"#808080\",\n            fillColor: \"\",\n            bold: false,\n            italic: false,\n        },\n        {\n            enabled: true,\n            threshold: -500,   // catches negative values between -999 and -500\n            format: \"#,##0\",\n            prefix: \"❌\",\n            fontColor: \"#C00000\",\n            fillColor: \"\",\n            bold: false,\n            italic: true,\n        },\n    ];\n\n    // DEFAULT fires for anything not matched by any tier:\n    // values between the lowest positive threshold and the lowest-magnitude negative threshold.\n    const DEFAULT: DefaultConfig = {\n        enabled: true,\n        format: \"#,##0\",\n        prefix: \"🤔\",\n        fontColor: \"#808080\",\n        fillColor: \"\",\n        bold: true,\n        italic: false,\n    };\n\n    // ─── SCRIPT — no edits needed below this line ─────────────────────────────\n\n    const range = workbook.getSelectedRange();\n    if (!range) { console.log(\"No range selected.\"); return; }\n\n    const anchor = DEFAULT.enabled\n        ? range.getCell(0, 0).getAddress().split(\"!\")[1].replace(/\\$/g, \"\")\n        : \"\";\n\n    range.clearAllConditionalFormats();\n\n    function buildFormat(base: string, prefix: string): string {\n      if (!APPLY_PREFIX || prefix === \"\" || base === \"\") return base;\n      if (PREFIX_POSITION === \"fill\") {\n        return `\"${prefix} \"* ${base};\"${prefix} \"* -${base}`;\n      } else {\n        return `\"${prefix} \"${base};\"${prefix} \"-${base}`;\n      }\n    }\n\n    function applyStyle(fmt: ExcelScript.ConditionalRangeFormat, cfg: StyleConfig): void {\n        if (!APPLY_FONT_STYLING) return;\n        const font = fmt.getFont();\n        if (cfg.fontColor !== \"\") font.setColor(cfg.fontColor);\n        font.setBold(cfg.bold);\n        font.setItalic(cfg.italic);\n        if (cfg.fillColor !== \"\") fmt.getFill().setColor(cfg.fillColor);\n    }\n\n    function applyTiers(\n        tiers: TierConfig[],\n        operator: ExcelScript.ConditionalCellValueOperator\n    ): void {\n        for (const tier of tiers) {\n            if (!tier.enabled) continue;\n            const cf = range.addConditionalFormat(ExcelScript.ConditionalFormatType.cellValue);\n            cf.setStopIfTrue(true);\n            const cv = cf.getCellValue();\n            cv.setRule({ formula1: String(tier.threshold), operator });\n            const fmt = cv.getFormat();\n            fmt.setNumberFormat(buildFormat(tier.format, tier.prefix));\n            applyStyle(fmt, tier);\n        }\n    }\n\n    applyTiers(POSITIVE_TIERS, ExcelScript.ConditionalCellValueOperator.greaterThanOrEqual);\n    applyTiers(NEGATIVE_TIERS, ExcelScript.ConditionalCellValueOperator.lessThanOrEqual);\n\n    if (DEFAULT.enabled) {\n        const cf = range.addConditionalFormat(ExcelScript.ConditionalFormatType.custom);\n        cf.getCustom().getRule().setFormula(`=ISNUMBER(${anchor})`);\n        const fmt = cf.getCustom().getFormat();\n        if (DEFAULT.format !== \"\") fmt.setNumberFormat(buildFormat(DEFAULT.format, DEFAULT.prefix));\n        applyStyle(fmt, DEFAULT);\n    }\n\n    console.log(`Applied to ${range.getAddress()}.`);\n}","description":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[],\"parameterSchema\":{\"type\":\"object\",\"default\":{},\"x-ms-visibility\":\"internal\"},\"returnSchema\":{\"type\":\"object\",\"properties\":{}},\"signature\":{\"comment\":\"\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}