{"version":"0.3.0","body":"//  These interfaces define the shape of the TIERS and DEFAULT config objects so please don't edit them.\n\n// Shared styling properties used by both TierConfig and DefaultConfig.\ninterface StyleConfig {\n    prefix: string;      // symbol or emoji prepended to the number; \"\" = none\n    fontColor: string;   // hex font color e.g. \"#C00000\"; \"\" = keep existing\n    fillColor: string;   // hex cell background color e.g. \"#FFF2CC\"; \"\" = no fill\n    bold: boolean;       // true = bold font; false = regular weight\n    italic: boolean;     // true = italic font; false = upright\n}\n\n// Defines one magnitude tier (one conditional formatting rule per tier).\ninterface TierConfig extends StyleConfig {\n    enabled: boolean;   // false = this tier is skipped entirely; no rule is added\n    threshold: number;  // lower-bound (inclusive); all tiers use >=\n    format: string;     // Excel number format string without the prefix — see README\n}\n\n// Defines the catch-all rule for numeric cells not matched by any enabled tier.\n// For positive-only data with all tiers enabled, this only works for values lower than the lowest threshold\ninterface DefaultConfig extends StyleConfig {\n    enabled: boolean;   // false = unmatched numeric cells are left completely untouched\n    format: string;     // Excel number format string; \"\" = no format change (prefix also suppressed)\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction main(workbook: ExcelScript.Workbook): void {\n\n    // ─── CONFIGURATION — we edit everything in this section based on our needs ──────────────\n\n    const APPLY_FONT_STYLING = true;   // false = skip all font/fill styling\n    const APPLY_PREFIX = true;         // false = skip all prefix symbols\n    const PREFIX_POSITION: \"before\" | \"fill\" = \"fill\";\n    // \"before\" = prefix immediately left of number\n    // \"fill\"   = prefix at left cell edge, number at right\n\n    // Tiers are evaluated top-to-bottom; make sure to keep thresholds in descending order to get correct results. (B → M → K → n).\n    // The last entry uses threshold: n (a value below 1000 based on this script's tiers and can be 0) to catch\n    // all values below the K tier and at the end, DEFAULT handles anything that falls through.\n    const TIERS: TierConfig[] = [\n        {\n            enabled: true,\n            threshold: 1_000_000_000,\n            format: '0.00,,,\"B\"',\n            prefix: \"🟢\",\n            fontColor: \"\",\n            fillColor: \"\",\n            bold: false,\n            italic: false,\n        },\n        {\n            enabled: true,\n            threshold: 1_000_000,\n            format: '0.00,,\"M\"',\n            prefix: \"🔵\",\n            fontColor: \"#1F497D\",\n            fillColor: \"\",\n            bold: false,\n            italic: false,\n        },\n        {\n            enabled: true,\n            threshold: 1_000,\n            format: '0.00,\"K\"',\n            prefix: \"🔴\",\n            fontColor: \"#808080\",\n            fillColor: \"\",\n            bold: true,\n            italic: false,\n        },\n        {\n            enabled: true,\n            threshold: 500,   // catches all positive values below the K tier till the specified value here\n            format: \"#,##0\",\n            prefix: \"❌\",\n            fontColor: \"#C00000\",\n            fillColor: \"\",\n            bold: false,\n            italic: true,\n        },\n    ];\n\n    // DEFAULT fires when no tier matched.\n    const DEFAULT: DefaultConfig = {\n        enabled: true,\n        format: \"#,##0\",\n        prefix: \"🤔\",\n        fontColor: \"#808080\",\n        fillColor: \"\",\n        bold: true,\n        italic: false,\n    };\n\n    // ─── SCRIPT — no edits needed ─────────────────────────────\n\n    const range = workbook.getSelectedRange();\n    if (!range) { console.log(\"No range selected.\"); return; }\n\n    // Anchor is only needed for the DEFAULT formula rule, compute it lazily.\n    const anchor = DEFAULT.enabled\n        ? range.getCell(0, 0).getAddress().split(\"!\")[1].replace(/\\$/g, \"\")\n        : \"\";\n\n    range.clearAllConditionalFormats();\n\n    function buildFormat(base: string, prefix: string): string {\n        if (!APPLY_PREFIX || prefix === \"\" || base === \"\") return base;\n        return PREFIX_POSITION === \"fill\"\n            ? `\"${prefix} \"* ` + base\n            : `\"${prefix} \"` + base;\n    }\n\n    function applyStyle(fmt: ExcelScript.ConditionalRangeFormat, cfg: StyleConfig): void {\n        if (!APPLY_FONT_STYLING) return;\n        const font = fmt.getFont();\n        if (cfg.fontColor !== \"\") font.setColor(cfg.fontColor);\n        font.setBold(cfg.bold);\n        font.setItalic(cfg.italic);\n        if (cfg.fillColor !== \"\") fmt.getFill().setColor(cfg.fillColor);\n    }\n\n    // setStopIfTrue(true) prevents lower-priority rules (including DEFAULT) from firing on matched cells.\n    for (const tier of TIERS) {\n        if (!tier.enabled) continue;\n        const cf = range.addConditionalFormat(ExcelScript.ConditionalFormatType.cellValue);\n        cf.setStopIfTrue(true);\n        const cv = cf.getCellValue();\n        cv.setRule({\n            formula1: String(tier.threshold),\n            operator: ExcelScript.ConditionalCellValueOperator.greaterThanOrEqual,\n        });\n        const fmt = cv.getFormat();\n        fmt.setNumberFormat(buildFormat(tier.format, tier.prefix));\n        applyStyle(fmt, tier);\n    }\n\n    // DEFAULT: lowest priority that fires only when no tier matched.\n    if (DEFAULT.enabled) {\n        const cf = range.addConditionalFormat(ExcelScript.ConditionalFormatType.custom);\n        cf.getCustom().getRule().setFormula(`=ISNUMBER(${anchor})`);\n        const fmt = cf.getCustom().getFormat();\n        if (DEFAULT.format !== \"\") fmt.setNumberFormat(buildFormat(DEFAULT.format, DEFAULT.prefix));\n        applyStyle(fmt, DEFAULT);\n    }\n\n    console.log(`Applied to ${range.getAddress()}.`);\n}\n","description":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[],\"parameterSchema\":{\"type\":\"object\",\"default\":{},\"x-ms-visibility\":\"internal\"},\"returnSchema\":{\"type\":\"object\",\"properties\":{}},\"signature\":{\"comment\":\"\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}