{"version":"0.3.0","body":"\ninterface ThresholdRule {\n    enabled: boolean;         // false = skip this rule entirely; no CF added\n    label: string;            // human-readable name used in console output only\n    prefix: string;           // symbol prepended to the cell value\n    stopIfTrue: boolean;      // true = cells matched here skip all lower-priority rules\n    formulaTemplate: string;  // Excel formula string; {A} is replaced at runtime\n    // with the anchor cell (e.g. G2) — relative, no $, so it shifts correctly for every row in the range.\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction main(workbook: ExcelScript.Workbook): void {\n\n    // ─── CONFIGURATION — we can edit everything in this section based on our needs ───\n\n    // Change these only if you rename the cells in the Name Manager.\n    const TARGET_NAME = \"target_value\";         // the benchmark (e.g. 250,000)\n    const BONUS_NAME = \"bonus_threshold\";      // multiplier above target (e.g. 1.15)\n    const ATTENTION_NAME = \"attention_threshold\";  // multiplier below target (e.g. 0.85)\n\n    // Number format applied to all matched cells.\n    const NUMBER_FORMAT = \"#,##0\";\n\n    // Prefix alignment:\n    //   \"fill\"   — prefix pinned to left cell edge, number right-aligned (dashboard style)\n    //   \"before\" — prefix immediately left of the number\n    const PREFIX_POSITION: \"before\" | \"fill\" = \"fill\";\n\n    // ─── RULES ───────────────────────────────────────────────────────────────\n    // To add more tiers follow this instruction (a \"critical\" tier below attention):\n    //   1. Add a named cell for the new multiplier in Excel Name Manager.\n    //   2. Add a new ThresholdRule entry below in the appropriate position.\n    //   3. Update the \"attention\" formulaTemplate if the new tier carves out a sub-range from it (e.g. attention becomes AND instead of <=).\n\n    // In the rules below, I put the normal as the first rule because it covers the majority of cells.\n    const RULES: ThresholdRule[] = [\n        {\n\n            enabled: true,\n            label: \"normal\",\n            prefix: \"·\",     // middle dot (U+00B7) — intentionally invisible at a glance\n            // alternatives: \"–\" (en dash), \"○\", \"✓\" depending on context\n            stopIfTrue: true,\n            formulaTemplate: `=AND({A}>${ATTENTION_NAME}*${TARGET_NAME},{A}<${BONUS_NAME}*${TARGET_NAME})`,\n        },\n        {\n            // At or above bonus threshold.\n            enabled: true,\n            label: \"bonus\",\n            prefix: \"⭐\",\n            stopIfTrue: true,\n            formulaTemplate: `={A}>=${BONUS_NAME}*${TARGET_NAME}`,\n        },\n        {\n            // At or below attention threshold.\n            enabled: true,\n            label: \"attention\",\n            prefix: \"❌\",\n            stopIfTrue: false,  // last rule; stopIfTrue has no effect but kept for consistency\n            formulaTemplate: `={A}<=${ATTENTION_NAME}*${TARGET_NAME}`,\n        },\n    ];\n\n    // ─── SCRIPT — no edits needed below this line ────────────────────────────\n\n    const range = workbook.getSelectedRange();\n    if (!range) { console.log(\"No range selected.\"); return; }\n\n    // Validate all required named ranges exist before touching any formatting.\n    // A missing name would produce silent #NAME? errors in the CF formulas.\n    for (const name of [TARGET_NAME, BONUS_NAME, ATTENTION_NAME]) {\n        if (!workbook.getNamedItem(name)) {\n            console.log(`Error: named range \"${name}\" not found in workbook. Aborting.`);\n            return;\n        }\n    }\n\n    // Top-left cell of the selection as a relative reference (no $ signs).\n    // A relative anchor shifts per row when Excel evaluates the CF formula\n    // across the range, so each cell evaluates against itself.\n    const anchor = range.getCell(0, 0).getAddress().split(\"!\")[1].replace(/\\$/g, \"\");\n\n    range.clearAllConditionalFormats();\n\n    function buildFormat(prefix: string): string {\n        if (!prefix) return NUMBER_FORMAT;\n        return PREFIX_POSITION === \"fill\"\n            ? `\"${prefix} \"* ${NUMBER_FORMAT}`\n            : `\"${prefix} \"` + NUMBER_FORMAT;\n    }\n\n    let applied = 0;\n    for (const rule of RULES) {\n        if (!rule.enabled) continue;\n        // Global replace: AND templates contain {A} twice.\n        const formula = rule.formulaTemplate.replace(/\\{A\\}/g, anchor);\n        const cf = range.addConditionalFormat(ExcelScript.ConditionalFormatType.custom);\n        cf.setStopIfTrue(rule.stopIfTrue);\n        cf.getCustom().getRule().setFormula(formula);\n        cf.getCustom().getFormat().setNumberFormat(buildFormat(rule.prefix));\n        applied++;\n    }\n\n    console.log(`Applied ${applied} rule(s) to ${range.getAddress()}.`);\n}","description":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[],\"parameterSchema\":{\"type\":\"object\",\"default\":{},\"x-ms-visibility\":\"internal\"},\"returnSchema\":{\"type\":\"object\",\"properties\":{}},\"signature\":{\"comment\":\"\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}