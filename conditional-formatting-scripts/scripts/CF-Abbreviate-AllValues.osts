{"version":"0.3.0","body":"function main(workbook: ExcelScript.Workbook): void {\n  const range = workbook.getSelectedRange();\n  if (!range) {\n    console.log(\"No range selected. Select a cell, range, or table column first.\");\n    return;\n  }\n\n  // Cell proxy for (0,0) — address extracted from the first cell of the selection.\n  const anchor: string = range.getCell(0, 0).getAddress().split(\"!\")[1].replace(/\\$/g, \"\");\n\n  range.clearAllConditionalFormats();\n\n  // Trailing commas in the format code divide the display value by 1,000 each (K/M/B scaling).\n  // ABS() in the formula covers negatives with one rule per tier instead of two.\n  // Remember that the first rule added keeps priority 1. B must win before M or K are evaluated.\n  // just like the script for positives, the number formatting and decimal places inconsistencies are intentional and the value 1.95 is shown as 0.0K which is expected.\n  const tiers: { threshold: number; format: string }[] = [\n    { threshold: 1_000_000_000, format: '#.00,,,\"B\"' },\n    { threshold: 1_000_000, format: '#.0,,\"M\"' },\n    { threshold: 1_000, format: '#.0,\"K\"' },\n    { threshold: 0, format: '0.0#,\"K\"' },\n  ];\n\n  for (const tier of tiers) {\n    const cf = range.addConditionalFormat(ExcelScript.ConditionalFormatType.custom);\n    // Stop If True: once a tier matches, lower-priority rules are skipped for that cell.\n    cf.setStopIfTrue(true);\n    const custom = cf.getCustom();\n    custom.getRule().setFormula(`=ABS(${anchor})>=${tier.threshold}`);\n    custom.getFormat().setNumberFormat(tier.format);\n  }\n\n  console.log(`Applied to ${range.getAddress()}.`);\n}","description":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[],\"parameterSchema\":{\"type\":\"object\",\"default\":{},\"x-ms-visibility\":\"internal\"},\"returnSchema\":{\"type\":\"object\",\"properties\":{}},\"signature\":{\"comment\":\"\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}